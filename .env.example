# Embeddings
QG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QG_EMBEDDING_DEVICE=cuda
QG_USE_HASH_EMBEDDINGS=0

# Generation (optional)
QG_ENABLE_LLM=1
QG_LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
QG_MAX_NEW_TOKENS=160
QG_MAX_NEW_TOKENS_DIAGRAM=280
QG_TEMPERATURE=0.0
QG_TOP_P=1.0

# Context budget for RAG prompt
QG_MAX_CONTEXT_CHARS=12000
QG_MAX_CHUNK_CONTEXT_CHARS=2000

# OCR fallback for scanned/image-heavy PDFs (diagram pages)
QG_ENABLE_OCR=1
QG_OCR_MIN_PAGE_CHARS=80
QG_OCR_MAX_PAGES=40
QG_OCR_DPI=180
QG_OCR_LANG=eng
# Optional absolute path if tesseract is not on PATH
QG_TESSERACT_CMD=
